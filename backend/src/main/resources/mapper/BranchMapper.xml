<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.book.mapper.BranchMapper">

    <resultMap id="BranchMap" type="com.example.book.entity.Branch">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="address" column="address"/>
        <result property="latitude" column="latitude"/>
        <result property="longitude" column="longitude"/>
        <result property="phone" column="phone"/>
        <result property="businessHours" column="business_hours"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO branch (
            name, address, latitude, longitude, phone, business_hours, status
        ) VALUES (
            #{name}, #{address}, #{latitude}, #{longitude}, #{phone}, #{businessHours}, #{status}
        )
    </insert>

    <update id="update">
        UPDATE branch
        SET name = #{name},
            address = #{address},
            latitude = #{latitude},
            longitude = #{longitude},
            phone = #{phone},
            business_hours = #{businessHours},
            status = #{status}
        WHERE id = #{id}
    </update>

    <select id="findById" resultMap="BranchMap">
        SELECT * FROM branch WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="BranchMap">
        SELECT * FROM branch ORDER BY id ASC
    </select>

    <select id="findByStatus" resultMap="BranchMap">
        SELECT * FROM branch WHERE status = #{status} ORDER BY id ASC
    </select>

</mapper>
