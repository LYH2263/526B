<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.book.mapper.PurchaseRequestLogMapper">

    <resultMap id="PurchaseRequestLogMap" type="com.example.book.entity.PurchaseRequestLog">
        <id property="id" column="id"/>
        <result property="requestId" column="request_id"/>
        <result property="fromStatus" column="from_status"/>
        <result property="toStatus" column="to_status"/>
        <result property="operatorId" column="operator_id"/>
        <result property="operatorName" column="operator_name"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO purchase_request_log (
            request_id, from_status, to_status, operator_id, operator_name, remark
        ) VALUES (
            #{requestId}, #{fromStatus}, #{toStatus}, #{operatorId}, #{operatorName}, #{remark}
        )
    </insert>

    <select id="findByRequestId" resultMap="PurchaseRequestLogMap">
        SELECT * FROM purchase_request_log WHERE request_id = #{requestId} ORDER BY created_at ASC
    </select>

</mapper>
